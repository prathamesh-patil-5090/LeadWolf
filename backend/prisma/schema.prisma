generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  ENRICHED
  DOMAIN_FOUND
  CONTACT_FOUND
  VERIFIED
  EMAIL_GENERATED
  SENT
  OPENED
  REPLIED
}

enum LeadSearchJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Lead {
  id              String     @id @default(cuid())
  name            String
  role            String
  company         String
  profileUrl      String     @unique
  location        String?
  website         String?
  portfolioUrl    String?
  companyWebsite  String?
  companySize     String?
  githubUrl       String?
  linkedinUrl     String?
  email           String?
  emailSource     String?
  discoveredContacts Json?
  verified        Boolean    @default(false)
  status          LeadStatus @default(NEW)
  companyId       String?
  companyRecord   Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  searchJobId     String?
  searchJob       LeadSearchJob? @relation(fields: [searchJobId], references: [id], onDelete: SetNull)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
  @@index([company])
  @@index([role])
  @@index([searchJobId])
  @@index([companyId])
}

model Company {
  id                   String    @id @default(cuid())
  name                 String
  domain               String    @unique
  website              String?
  scrapedContent       String?   @db.Text
  summary              String?   @db.Text
  industry             String?
  products             String?   @db.Text
  personalizationHooks Json?
  discoveredEmails     Json?
  discoveredAt         DateTime?
  summarizedAt         DateTime?
  leads                Lead[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([name])
}

model LeadSearchJob {
  id         String              @id @default(cuid())
  query      String
  role       String?
  location   String?
  company    String?
  roles         String[]            @default([])
  expandTechRoles Boolean           @default(true)
  limit      Int                 @default(25)
  status     LeadSearchJobStatus @default(PENDING)
  leadsFound Int                 @default(0)
  error      String?
  leads      Lead[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}
