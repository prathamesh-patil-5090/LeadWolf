generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  ENRICHED
  DOMAIN_FOUND
  CONTACT_FOUND
  VERIFIED
  EMAIL_GENERATED
  SENT
  OPENED
  REPLIED
}

enum LeadSearchJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Lead {
  id          String     @id @default(cuid())
  name        String
  role        String
  company     String
  profileUrl  String     @unique
  website     String?
  githubUrl   String?
  email       String?
  verified    Boolean    @default(false)
  status      LeadStatus @default(NEW)
  searchJobId String?
  searchJob   LeadSearchJob? @relation(fields: [searchJobId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([company])
  @@index([role])
  @@index([searchJobId])
}

model LeadSearchJob {
  id         String              @id @default(cuid())
  query      String
  role       String?
  location   String?
  company    String?
  limit      Int                 @default(25)
  status     LeadSearchJobStatus @default(PENDING)
  leadsFound Int                 @default(0)
  error      String?
  leads      Lead[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}
