# CORS for Next.js dashboard (comma-separated origins)
# CORS_ORIGIN=http://localhost:3000,https://your-domain.com


# PostgreSQL — put your real URL in .env (not here). Prisma CLI reads backend/.env only.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Upstash Redis TCP URL (only when LEAD_SEARCH_SYNC=false)
# REDIS_URL="rediss://default:PASSWORD@ENDPOINT.upstash.io:6379"

# Run lead search in-process without Redis/BullMQ (good for local dev)
LEAD_SEARCH_SYNC=true
LEAD_ENRICHMENT_SYNC=true
LEAD_COMPANY_DISCOVERY_SYNC=true
LEAD_CONTACT_DISCOVERY_SYNC=true
LEAD_PIPELINE_AUTO=true
LEAD_CONTACT_VERIFICATION_SYNC=true
LEAD_EMAIL_PERSONALIZATION_SYNC=true

# Groq — fast inference (key starts with gsk_)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — parallel email generation (instruct models only, not content-safety)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
# OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.2-3b-instruct:free,qwen/qwen-2.5-7b-instruct:free

# Outreach sender + CRag signature
# OUTREACH_SENDER_NAME=Prathamesh Patil
# OUTREACH_SENDER_TITLE=Full-Stack AI Engineer
# OUTREACH_SENDER_COMPANY=CRag
# OUTREACH_SENDER_LINKEDIN=https://linkedin.com/in/prathameshpatil5090
# OUTREACH_SENDER_GITHUB=https://github.com/prathamesh-patil-5090
# OUTREACH_SENDER_EMAIL=prathampatil7798@gmail.com
# OUTREACH_SENDER_ALT_EMAIL=cragai.tech@gmail.com
# OUTREACH_SENDER_CONTACT_EMAILS=prathampatil7798@gmail.com / cragai.tech@gmail.com
# OUTREACH_SENDER_WHATSAPP=+91 8421779259
# OUTREACH_SENDER_PITCH=CRag is an AI-Powered Engineering Knowledge Platform that reduces onboarding time and eliminates documentation drift

# Brevo campaign sending
# BREVO_API_KEY=
# BREVO_TEST_MODE=true
# BREVO_TEST_RECIPIENT=your-test@gmail.com
# LEAD_CAMPAIGN_SENDING_SYNC=true
# BREVO_REPLY_DOMAIN=reply.yourdomain.com
# BREVO_WEBHOOK_SECRET=choose-a-long-random-string

# Brevo webhooks (configure in Brevo dashboard or API):
#   POST https://your-vps/api/webhooks/brevo/transactional
#   POST https://your-vps/api/webhooks/brevo/inbound
# Transactional events: delivered, opened, click, hardBounce, softBounce, spam
# Inbound: type=inbound, events=inboundEmailProcessed, domain=BREVO_REPLY_DOMAIN

# Automated pipeline (BullMQ queue — requires REDIS_URL)
# LEAD_PIPELINE_SYNC=false
# LEAD_PIPELINE_AUTO=true
# LEAD_PIPELINE_AUTO_SEND=true
# LEAD_PIPELINE_AUTO_RETRY=true
# LEAD_PIPELINE_RETRY_INTERVAL_MS=60000
# LEAD_PIPELINE_RETRY_BATCH=10

# LEAD_PIPELINE_AUTO_GMAIL_SYNC=true
# GMAIL_REPLY_SYNC_BATCH=30

# Rate limits (automation safety — tune to your provider tiers)
# GROQ_RATE_LIMIT_RPM=30
# GROQ_RATE_LIMIT_RPD=1000
# OPENROUTER_RATE_LIMIT_RPM=20
# BREVO_RATE_LIMIT_RPD=300
# LEAD_PIPELINE_MAX_LEADS_PER_SEARCH=25  # removed — all new leads are queued

# Gmail reply sync (free — polls your inbox when sender is Gmail)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_REPLY_QUERY=in:inbox newer_than:30d

# Lead discovery — github (default) | combined | bright_data | mock | playwright
# With BRIGHT_DATA_API_KEY set, github runs in parallel with Bright Data by default.
LEAD_SEARCH_PROVIDER=github
LEAD_SEARCH_BRIGHT_DATA_PARALLEL=true
# LEAD_SEARCH_GITHUB_LIMIT=25
# LEAD_SEARCH_BRIGHT_DATA_LIMIT=25

# Bright Data LinkedIn scraping (collect-by-url only on most accounts)
# BRIGHT_DATA_API_KEY=
# BRIGHT_DATA_LINKEDIN_PROFILE_DATASET_ID=gd_l1viktl72bvl7bjuj0
# BRIGHT_DATA_POLL_INTERVAL_MS=5000
# BRIGHT_DATA_POLL_TIMEOUT_MS=300000
# LinkedIn URL discovery (for Bright Data profile scraping)
# LangSearch — free web search API: https://langsearch.com/
# LANGSEARCH_API_KEY=

